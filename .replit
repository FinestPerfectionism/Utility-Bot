[languages.python]
pattern = "**/*.py"

[languages.python.lsp]
name = "pyright"
command = ["pyright-langserver", "--stdio"]

[languages.python.languageServer]
start = "pyright-langserver --stdio"

run = "python3 main.py"

[nix]
channel = "stable-24_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Bot"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "source .bashrc && python3 main.py"

[[workflows.workflow]]
name = "Run Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 main.py"

[agent]
expertMode = true

[[ports]]
localPort = 5904
externalPort = 80

[shell]
shellAlias = "alias cff='find . -type f 2>/dev/null | grep -vE \"\\.venv|\\.cache|pythonlibs|\\.local\" | xargs wc -l | awk \"\\$1 >= 300 && \\$2 != \\\"total\\\"\" | sort -rn' && alias checkfilefill='cff'"